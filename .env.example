# Plantilla para .env.test / .env.uat / .env.prod
# Copia este archivo a .env.<env> y completa los valores.
# IMPORTANTE: los .env.* NO se commitean (estan en .gitignore).
# NOTA: las URLs con # (hash) deben ir entrecomilladas porque dotenv las trata
# como comentario inline si no estan entre dobles comillas.

# === Entorno activo ===
ENV=test

# === Portal carrier V2 (Angular 18) ===
# URL real: apps-test.magiis.com/carrier/#/auth/login
BASE_URL=https://apps-test.magiis.com
LOGIN_PATH="/carrier/#/auth/login"
DASHBOARD_URL_PATTERN="/carrier/#/dashboard"

# === Credenciales por region ===
# Region primaria (usada por global-setup y tests sin region).
USER_CARRIER=
PASS_CARRIER=

# Region secundaria (opcional para tests parametrizados por region: AR, MX, US, ...).
USER_CARRIER_AR=
PASS_CARRIER_AR=

# === Playwright runtime ===
HEADLESS=true
WORKERS=4
RETRIES=0

# === Referencia a V1 (Angular 8) - solo cuando ENABLE_V1_PARITY_TESTS=true ===
# URL real: apps-test.magiis.com/#/authentication/login/carrier
BASE_URL_V1=https://apps-test.magiis.com
LOGIN_PATH_V1="/#/authentication/login/carrier"
ENABLE_V1_PARITY_TESTS=false
